{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2019",
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": [
    "index.ts",
    "ProductOrdersInfoPlugin.ts",
    "constants.ts",
    "types.ts",
    "api/ProductOrdersInfoAdminResolver.ts",
    "api/graphql/admin/admin-api-extensions.ts",
    "service/ProductOrdersInfoService.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
